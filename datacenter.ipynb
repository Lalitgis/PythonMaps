import pandas as pd
import geopandas as gpd
import matplotlib.pyplot as plt
from matplotlib.colors import LinearSegmentedColormap

# ==========================================
# LOAD DATA
# ==========================================

df = pd.read_csv("datacenters_by_state.csv")

# ==========================================
# LOAD USA STATES SHAPEFILE
# ==========================================

states = gpd.read_file("cb_2018_us_state_500k.shp")

# Remove Alaska, Hawaii and territories
exclude = [
    "Alaska",
    "Hawaii",
    "Puerto Rico",
    "Guam",
    "American Samoa",
    "Commonwealth of the Northern Mariana Islands",
    "United States Virgin Islands"
]

states = states[~states["NAME"].isin(exclude)]

# ==========================================
# MERGE DATA
# ==========================================

gdf = states.merge(
    df,
    left_on="NAME",
    right_on="State",
    how="left"
)

# ==========================================
# CUSTOM PURPLE COLORMAP
# ==========================================

colors = [
    "#ead7ec",
    "#d9b4d7",
    "#c989c3",
    "#9c5a8c",
    "#5b2947"
]

cmap = LinearSegmentedColormap.from_list(
    "custom_purple",
    colors
)

# ==========================================
# CREATE FIGURE
# ==========================================

fig = plt.figure(
    figsize=(18, 8),
    facecolor="#f2f2f2"
)

ax = fig.add_axes([0.03, 0.08, 0.94, 0.72])
ax.set_facecolor("#f2f2f2")

# ==========================================
# DRAW MAP
# ==========================================

gdf.plot(
    column="Operational",
    cmap=cmap,
    linewidth=0.3,
    edgecolor="#2b2b2b",
    legend=True,
    ax=ax,
    missing_kwds={
        "color": "#dddddd"
    },
    legend_kwds={
        "orientation": "horizontal",
        "shrink": 0.60,
        "aspect": 40,
        "pad": 0.01
    }
)

# ==========================================
# FORMAT COLORBAR
# ==========================================

cbar = fig.axes[-1]

# [left, bottom, width, height]
cbar.set_position([
    0.25,
    0.84,
    0.35,
    0.018
])

cbar.tick_params(
    labelsize=10,
    colors="#666666"
)

cbar.set_title(
    "Operational Data Centers",
    fontsize=13,
    pad=8
)

# ==========================================
# TITLE
# ==========================================

fig.text(
    0.5,
    0.92,
    "Operational Data Centers by State",
    ha="center",
    fontsize=22,
    fontweight="bold"
)

# ==========================================
# TEXAS CALLOUT
# ==========================================

max_row = gdf.loc[gdf["Operational"].idxmax()]

point = max_row.geometry.representative_point()
ax.annotate(
    f"{max_row['NAME']}\n{max_row['Operational']}",
    xy=(point.x, point.y),
    xytext=(50, -110),
    textcoords="offset points",
    fontsize=12,
    fontweight="bold",
    color="#333333",
    ha="center",
    arrowprops=dict(
        arrowstyle="-",
        lw=1.5,
        color="#555555"
    )
)


# ==========================================
# REMOVE AXES
# ==========================================

# Remove axes
ax.axis("off")

# Zoom to continental US
ax.set_xlim(-125, -66)
ax.set_ylim(24, 50)

# Preserve map proportions
ax.set_aspect("equal")

#Adding the states name
for idx, row in gdf.iterrows():

    point = row.geometry.representative_point()

    ax.text(
        point.x,
        point.y,
        row["STUSPS"],  # CA, TX, FL, etc.
        fontsize=7,
        fontweight="bold",
        ha="center",
        va="center",
        color="black"
    )
plt.show()
